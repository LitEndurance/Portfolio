#!/bin/bash
#
# Commit-msg hook for AI-driven development.
# Encourages descriptive commit messages.
#

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -n 1 "$COMMIT_MSG_FILE")

# Block single-word commit messages
WORD_COUNT=$(echo "$COMMIT_MSG" | wc -w)
if [ "$WORD_COUNT" -lt 2 ]; then
  echo "ERROR: Commit message is too short. Describe what changed and why."
  echo "Good: 'Add user authentication middleware'"
  echo "Bad:  'fix'"
  exit 1
fi

# Block placeholder commit messages
if echo "$COMMIT_MSG" | grep -qiE "^(update|changes|fix|wip|temp|asdf|qwerty|test|init)$"; then
  echo "ERROR: Commit message is too vague. Be specific about what changed."
  exit 1
fi

# Warn about AI-generated-looking messages that lack specificity
if echo "$COMMIT_MSG" | grep -qiE "^generated by|generated with|ai (generated|written|produced)"; then
  echo "WARNING: Commit message looks AI-generated. Make sure it accurately describes YOUR changes."
fi
